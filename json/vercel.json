{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/css/(.*)",
      "dest": "/css/$1"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/html/admin/$1"
    },
    {
      "src": "/quiz/(.*)",
      "dest": "/html/quiz/$1"
    },
    {
      "src": "/result/(.*)",
      "dest": "/html/result/$1"
    },
    {
      "src": "/welcome.html",
      "dest": "/html/welcome.html"
    },
    {
      "src": "/import.html",
      "dest": "/html/import.html"
    },
    {
      "src": "/(index.html)?",
      "dest": "/html/index.html"
    }
  ]
}
